# ML_hostel AI service — configuration (all optional except the shared secret).
# These are consumed by docker-compose and passed into the ml_hostel container.

# MUST match the Django backend's ML_SHARED_SECRET exactly — the service verifies
# the context token Django mints with this key. No fallback: unset = fail closed.
ML_SHARED_SECRET=change-me-to-a-long-random-string

# Django gateway (service-internal). The service's only door to business data.
ML_DJANGO_API_URL=http://web:8000/api

# LLM provider selection (provider-agnostic; switch with config only):
#   ollama (self-hosted, local dev) | gemini | openai | groq | openrouter
ML_PROVIDER=ollama
# Model + embedding default sensibly per provider if left blank; override here:
#   ollama → llama3.2:3b / nomic-embed-text
#   gemini → gemini-flash-latest / gemini-embedding-001
ML_MODEL=llama3.2:3b
ML_EMBED_MODEL=
ML_TEMPERATURE=0.2
ML_MAX_TOOL_ROUNDS=4

# Ollama backend (ML_PROVIDER=ollama)
ML_OLLAMA_URL=http://ollama:11434

# Google Gemini (ML_PROVIDER=gemini) — via its OpenAI-compatibility layer.
# ML_GEMINI_API_KEY=your-gemini-key
# ML_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Other OpenAI-compatible backends
# ML_OPENAI_API_KEY=
# ML_OPENAI_BASE_URL=https://api.openai.com/v1
# ML_GROQ_API_KEY=

# CORS — leave empty when the browser reaches the service same-origin via the
# dev gateway (/ai). REQUIRED in prod: set to the admin origin(s), since the
# browser opens the SSE stream cross-origin (no gateway in prod).
# ML_ALLOWED_ORIGINS=https://your-admin.vercel.app
