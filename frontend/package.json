{
  "name": "hostel-frontend",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @hostel/client",
    "dev:client": "npm run dev --workspace @hostel/client",
    "dev:admin": "npm run dev --workspace @hostel/admin",
    "build": "npm run build --workspaces --if-present",
    "build:client": "npm run build --workspace @hostel/client",
    "build:admin": "npm run build --workspace @hostel/admin",
    "start:client": "npm run start --workspace @hostel/client",
    "start:admin": "npm run start --workspace @hostel/admin",
    "lint": "eslint",
    "typecheck": "tsc --noEmit -p apps/client && tsc --noEmit -p apps/admin",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install --with-deps chromium firefox",
    "e2e:update-snapshots": "playwright test regression --update-snapshots",
    "start:test": "node scripts/start-zones.mjs",
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "cy:component": "cypress run --component",
    "cy:ci": "start-server-and-test start:test http://localhost:3100 cy:run",
    "lhci": "lhci autorun"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/cypress": "^10.0.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.24",
    "babel-plugin-react-compiler": "1.0.0",
    "cypress": "^15.18.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.10",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4.1.18",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1",
    "vite": "^7.0.0",
    "cookie": "^0.7.0",
    "qs": "^6.15.3"
  }
}
