# syntax=docker/dockerfile:1
# =============================================================================
# Hostel SaaS — ADMIN zone (Next.js) production image
# Build context is the WORKSPACE ROOT (./frontend), dockerfile lives in the app:
#   docker build -f apps/admin/Dockerfile .
# Multi-stage build leveraging Next.js "standalone" output: the final image
# ships only the minimal server bundle + static assets, no full node_modules.
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1 — deps: install workspace node_modules from a clean lockfile
# -----------------------------------------------------------------------------
FROM node:22-alpine AS deps
WORKDIR /app
# npm ci needs every workspace manifest to resolve the tree.
COPY package.json package-lock.json ./
COPY apps/admin/package.json ./apps/admin/
COPY apps/client/package.json ./apps/client/
COPY packages/api/package.json ./packages/api/
COPY packages/auth/package.json ./packages/auth/
COPY packages/config/package.json ./packages/config/
COPY packages/hooks/package.json ./packages/hooks/
COPY packages/permissions/package.json ./packages/permissions/
COPY packages/pwa/package.json ./packages/pwa/
COPY packages/types/package.json ./packages/types/
COPY packages/ui/package.json ./packages/ui/
COPY packages/utils/package.json ./packages/utils/
# Test-only tooling (the Cypress app binary, Playwright browsers) is never used
# to build or run the production image, yet Cypress's postinstall pulls a
# several-hundred-MB binary from download.cypress.io — which dominates, and on a
# slow link times out, `npm ci`. Skip those binary fetches (the npm packages
# still install, just without their runtime binaries) and make npm tolerant of a
# slow/flaky registry connection.
ENV CYPRESS_INSTALL_BINARY=0 \
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
RUN npm ci --no-audit --no-fund \
      --fetch-retries=5 \
      --fetch-retry-mintimeout=20000 \
      --fetch-retry-maxtimeout=120000 \
      --fetch-timeout=600000

# -----------------------------------------------------------------------------
# Stage 2 — builder: compile the admin app (standalone output)
# -----------------------------------------------------------------------------
FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# NEXT_PUBLIC_* values are inlined into the client bundle at build time, so the
# backend URL the browser will call must be supplied here.
ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
# VAPID public key for Web Push — inlined so the installed PWA can subscribe.
# Empty by default; push UI hides itself until this is provided.
ARG NEXT_PUBLIC_VAPID_PUBLIC_KEY=
ENV NEXT_PUBLIC_VAPID_PUBLIC_KEY=${NEXT_PUBLIC_VAPID_PUBLIC_KEY}
# Wildcard base domain for workspace subdomains (<slug>.<domain>) — inlined
# into the workspace-username UI, X-Workspace header logic and edge proxy.
ARG NEXT_PUBLIC_TENANT_BASE_DOMAIN=localhost
ENV NEXT_PUBLIC_TENANT_BASE_DOMAIN=${NEXT_PUBLIC_TENANT_BASE_DOMAIN}
ENV NEXT_TELEMETRY_DISABLED=1
# Emit the self-contained standalone server bundle this image copies below.
# (Off by default so Vercel/other hosts build without the standalone copy step.)
ENV NEXT_OUTPUT_STANDALONE=1

RUN npm run build --workspace @hostel/admin

# -----------------------------------------------------------------------------
# Stage 3 — runner: minimal runtime, non-root
# -----------------------------------------------------------------------------
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Run as the unprivileged "node" user that ships with the base image.
# Monorepo standalone output nests the app under its workspace path and hoists
# a trimmed node_modules at the root.
COPY --from=builder --chown=node:node /app/apps/admin/.next/standalone ./
COPY --from=builder --chown=node:node /app/apps/admin/.next/static ./apps/admin/.next/static
COPY --from=builder --chown=node:node /app/apps/admin/public ./apps/admin/public

USER node

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD node -e "fetch('http://127.0.0.1:3000/login').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

# server.js is generated by Next.js standalone output (nested per workspace).
CMD ["node", "apps/admin/server.js"]
