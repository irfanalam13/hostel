# syntax=docker/dockerfile:1
# =============================================================================
# Hostel SaaS — CLIENT zone (marketing site, Next.js) production image
# Build context is the WORKSPACE ROOT (./frontend), dockerfile lives in the app:
#   docker build -f apps/client/Dockerfile .
# The client zone owns the public origin and fallback-rewrites every
# non-marketing path to the admin zone (runtime env: ADMIN_ZONE_URL).
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1 — deps: install workspace node_modules from a clean lockfile
# -----------------------------------------------------------------------------
FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS deps
WORKDIR /app
# npm ci needs every workspace manifest to resolve the tree.
COPY package.json package-lock.json ./
COPY apps/admin/package.json ./apps/admin/
COPY apps/client/package.json ./apps/client/
COPY packages/api/package.json ./packages/api/
COPY packages/auth/package.json ./packages/auth/
COPY packages/config/package.json ./packages/config/
COPY packages/hooks/package.json ./packages/hooks/
COPY packages/permissions/package.json ./packages/permissions/
COPY packages/pwa/package.json ./packages/pwa/
COPY packages/types/package.json ./packages/types/
COPY packages/ui/package.json ./packages/ui/
COPY packages/utils/package.json ./packages/utils/
# Skip test-tool binary downloads (Cypress/Playwright) — see admin Dockerfile.
ENV CYPRESS_INSTALL_BINARY=0 \
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
RUN npm ci --no-audit --no-fund \
      --fetch-retries=5 \
      --fetch-retry-mintimeout=20000 \
      --fetch-retry-maxtimeout=120000 \
      --fetch-timeout=600000

# -----------------------------------------------------------------------------
# Stage 2 — builder: compile the client app (standalone output)
# -----------------------------------------------------------------------------
FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# NEXT_PUBLIC_* values are inlined into the client bundle at build time.
ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
# Wildcard base domain for workspace subdomains (<slug>.<domain>) — read by
# the shared edge proxy to tag workspace requests with x-workspace.
ARG NEXT_PUBLIC_TENANT_BASE_DOMAIN=localhost
ENV NEXT_PUBLIC_TENANT_BASE_DOMAIN=${NEXT_PUBLIC_TENANT_BASE_DOMAIN}
# Standalone output bakes rewrites into the routes manifest at BUILD time, so
# the admin-zone URL must be correct here — runtime env can't change it.
# http://admin:3000 matches the compose service; override for other topologies.
ARG ADMIN_ZONE_URL=http://admin:3000
ENV ADMIN_ZONE_URL=${ADMIN_ZONE_URL}
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_OUTPUT_STANDALONE=1

RUN npm run build --workspace @hostel/client

# -----------------------------------------------------------------------------
# Stage 3 — runner: minimal runtime, non-root
# -----------------------------------------------------------------------------
FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0
# Where the admin zone lives — next.config.ts reads this when the server boots,
# so it is runtime-configurable (compose sets http://admin:3000).
ENV ADMIN_ZONE_URL=http://admin:3000

COPY --from=builder --chown=node:node /app/apps/client/.next/standalone ./
COPY --from=builder --chown=node:node /app/apps/client/.next/static ./apps/client/.next/static

USER node

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD node -e "fetch('http://127.0.0.1:3000/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

# server.js is generated by Next.js standalone output (nested per workspace).
CMD ["node", "apps/client/server.js"]
