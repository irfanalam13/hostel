# syntax=docker/dockerfile:1
# =============================================================================
# Hostel SaaS — frontend (Next.js) production image
# Multi-stage build leveraging Next.js "standalone" output: the final image
# ships only the minimal server bundle + static assets, no full node_modules.
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1 — deps: install node_modules from a clean, reproducible lockfile
# -----------------------------------------------------------------------------
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

# -----------------------------------------------------------------------------
# Stage 2 — builder: compile the production build (standalone output)
# -----------------------------------------------------------------------------
FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# NEXT_PUBLIC_* values are inlined into the client bundle at build time, so the
# backend URL the browser will call must be supplied here.
ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
# VAPID public key for Web Push — inlined so the installed PWA can subscribe.
# Empty by default; push UI hides itself until this is provided.
ARG NEXT_PUBLIC_VAPID_PUBLIC_KEY=
ENV NEXT_PUBLIC_VAPID_PUBLIC_KEY=${NEXT_PUBLIC_VAPID_PUBLIC_KEY}
ENV NEXT_TELEMETRY_DISABLED=1
# Emit the self-contained standalone server bundle this image copies below.
# (Off by default so Vercel/other hosts build without the standalone copy step.)
ENV NEXT_OUTPUT_STANDALONE=1

RUN npm run build

# -----------------------------------------------------------------------------
# Stage 3 — runner: minimal runtime, non-root
# -----------------------------------------------------------------------------
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Run as the unprivileged "node" user that ships with the base image.
# Standalone output bundles a trimmed node_modules + the server entrypoint.
COPY --from=builder --chown=node:node /app/public ./public
COPY --from=builder --chown=node:node /app/.next/standalone ./
COPY --from=builder --chown=node:node /app/.next/static ./.next/static

USER node

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD node -e "fetch('http://127.0.0.1:3000/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

# server.js is generated by Next.js standalone output.
CMD ["node", "server.js"]
