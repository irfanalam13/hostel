# Dependencies — reinstalled inside the image from the lockfile
node_modules/
.pnp
.pnp.*

# Build output
.next/
out/
build/

# Env / secrets — never bake into an image
.env
.env.*
!.env.example

# VCS / editor / misc
.git/
.gitignore
Dockerfile
.dockerignore
*.md
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
*.tsbuildinfo
coverage/
.vercel

# Monorepo: per-app build output + test tooling never needed in images
apps/*/.next/
apps/*/out/
e2e/
cypress/
playwright-report/
test-results/
Documentation/
