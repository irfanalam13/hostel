# =============================================================================
# Repository-root ignore rules (in addition to backend/ and frontend/ rules)
# =============================================================================

# --- Secrets & local config — NEVER commit -------------------------------
# Broadened (Phase 1, §9): `*.env` did NOT match `.env.local` / `.env.production`
# (they don't end in `.env`), so those leaked past the filter. `.env.*` closes it;
# the `!` negations keep the committed *templates* only.
.env
*.env
.env.*
!.env.example
!.env.*.example
!.env.sample
# Production worker env (Oracle VM) — explicit, though covered by .env.* above.
.env.production
backend/.env.production

# --- Keys & certificates — NEVER commit ------------------------------------
# SSH/TLS private keys, PEM bundles (e.g. the Oracle VM key pair).
*.pem
*.key

# SOPS-encrypted secrets ARE safe to commit; plaintext age private keys are NOT.
*.agekey
age.key
age-key.txt
keys.txt
*.dec
*.decrypted
secrets/**/*.plain.*

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Databases & user data (may contain PII) --------------------------------
*.sqlite3
*.sqlite3-journal
*.sqlite3.bak*
/backend/media/
/backend/staticfiles/

# --- Node / Next.js ---------------------------------------------------------
node_modules/
.next/
out/
*.tsbuildinfo
.vercel

# --- Logs -------------------------------------------------------------------
logs/
*.log

# --- OS / editor ------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/

# --- Local tooling / scratch ------------------------------------------------
.mcp.json
/backups/
frontend/_capture_tmp.mjs
frontend/_students_shot.png
frontend/e2e/_debug_students.spec.ts
