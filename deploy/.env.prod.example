# =============================================================================
# Production / staging environment for deploy/docker-compose.prod.yml.
# Copy to deploy/.env on the VPS and fill in real values. NEVER commit the real
# file. Image refs (BACKEND_IMAGE / CLIENT_IMAGE / ADMIN_IMAGE) are managed by deploy.sh.
# =============================================================================

# --- Images (set/updated by deploy.sh; seed with the first release) ----------
BACKEND_IMAGE=ghcr.io/OWNER/hostel-backend:latest
CLIENT_IMAGE=ghcr.io/OWNER/hostel-client:latest
ADMIN_IMAGE=ghcr.io/OWNER/hostel-admin:latest

# --- Reverse proxy -----------------------------------------------------------
DOMAIN=app.yourdomain.com

# Nginx terminates TLS and owns the HSTS header (deploy/nginx/snippets/
# security-headers.conf). Set this to 0 so Django does NOT also emit HSTS on
# /api and /admin (avoids a duplicate Strict-Transport-Security header).
# SECURE_SSL_REDIRECT stays default (True) but is a no-op behind the nginx 301.
SECURE_HSTS_SECONDS=0

# Let's Encrypt automation (deploy/certbot). Used by init-letsencrypt.sh /
# renew.sh for the ACME account + expiry notices.
CERTBOT_EMAIL=admin@yourdomain.com

# --- Registry credentials (read:packages) used by deploy.sh ------------------
GHCR_USER=your-github-username
GHCR_TOKEN=ghp_xxx_read_packages_token

# --- Core Django (production) ------------------------------------------------
DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-strong-random-secret
ALLOWED_HOSTS=app.yourdomain.com
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://app.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com

# --- Database ----------------------------------------------------------------
POSTGRES_DB=hostel
POSTGRES_USER=hostel
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgres://hostel:change-me-strong-db-password@postgres:5432/hostel

# --- Redis / Celery ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Observability -----------------------------------------------------------
PROMETHEUS_ENABLED=True
SENTRY_DSN=

# --- Email / backups / push (see backend/.env.example for the full list) -----
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
BACKUP_ENCRYPTION_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# --- App version -------------------------------------------------------------
APP_VERSION=1.0.0

# --- Multi-tenant routing (Prompts 01/05) --------------------------------------
# Wildcard workspace domain: <workspace>.$TENANT_BASE_DOMAIN. Must match DOMAIN.
TENANT_BASE_DOMAIN=yourdomain.com
# Activated tenant custom domains must be listed in ALLOWED_HOSTS and
# CSRF_TRUSTED_ORIGINS (comma-separated) — see docs/CUSTOM_DOMAINS.md.

# --- Object storage (Prompt 06) -------------------------------------------------
# local = media volume on this host (single-node). s3 = S3/MinIO/R2 — required
# for multi-replica (stateless) web/worker scaling and CDN media offload.
STORAGE_BACKEND=local
# When STORAGE_BACKEND=s3:
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=hostel-media
# S3_ENDPOINT_URL=            # empty = AWS S3; http://minio:9000 for the bundled MinIO
# S3_REGION=auto
# S3_PUBLIC_DOMAIN=           # e.g. media.yourdomain.com (CDN)

# --- Resource limits (per container; tune to the host) --------------------------
# WEB_MEM_LIMIT=768m
# WEB_CPUS=1.5
# WORKER_MEM_LIMIT=512m
# WORKER_CPUS=1.0
# FRONTEND_MEM_LIMIT=512m
# ADMIN_MEM_LIMIT=512m

# --- Database hardening ----------------------------------------------------------
# Kill runaway queries after N ms (0 = provider default).
# DB_STATEMENT_TIMEOUT_MS=30000

# --- Traefik edge (only with docker-compose.traefik.yml) ------------------------
# LETSENCRYPT_EMAIL=admin@yourdomain.com
# TRAEFIK_DNS_PROVIDER=cloudflare
# CF_DNS_API_TOKEN=
