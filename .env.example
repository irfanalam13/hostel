# =============================================================================
# Hostel SaaS — Docker Compose environment (root)
#
# Copy to `.env` and fill in real values:   cp .env.example .env
# NEVER commit the real `.env` — it is git-ignored.
#
# This single file configures every service in docker-compose.yml. Per-
# environment differences are limited to the values marked below; the variable
# *names* are identical across development / staging / production.
#
#   DEVELOPMENT   DEBUG=True   self-signed defaults, console email, weak secrets ok
#   STAGING       DEBUG=False  real secrets, real DB/Redis, TLS, SMTP, Sentry
#   PRODUCTION    DEBUG=False  real secrets, hardened hosts/CORS, TLS, SMTP, Sentry
# =============================================================================

# --- Core Django ------------------------------------------------------------
# DEVELOPMENT: True   |   STAGING/PRODUCTION: False
DEBUG=False

# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-strong-random-secret

# Comma-separated. REQUIRED when DEBUG=False.
# DEVELOPMENT: localhost,127.0.0.1   |   PRODUCTION: api.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,web

# --- Database (PostgreSQL installed on the HOST, not in Docker) --------------
# Single source of truth: these vars are assembled into DATABASE_URL by
# docker-compose (see the x-postgres-dsn anchor), so the app and the database
# can never drift out of sync. Set a strong password.
# Do NOT set DATABASE_URL here for the Docker stack. (Managed hosts like Render
# set DATABASE_URL directly in their own dashboard instead.)
#
# POSTGRES_HOST is how the CONTAINERS reach the host machine's Postgres:
# `host.docker.internal` on Docker Desktop (Windows/Mac).
POSTGRES_DB=hostel
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432

# --- Redis / Celery ---------------------------------------------------------
# Compose talks to the `redis` service by name.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Multi-tenant workspaces (subdomain routing) ------------------------------
# Wildcard base domain: workspaces live at https://<username>.<TENANT_BASE_DOMAIN>
# DEVELOPMENT: localhost (http://everest.localhost:8000 works with zero DNS
# setup)   |   PRODUCTION: myhostel.com (requires wildcard DNS *.myhostel.com
# and a wildcard TLS cert; ".myhostel.com" is auto-added to ALLOWED_HOSTS).
TENANT_BASE_DOMAIN=localhost
# TENANT_URL_SCHEME=https
# Workspace-username rules (max is hard-capped at 63, the DNS label limit).
# WORKSPACE_USERNAME_MIN_LENGTH=3
# WORKSPACE_USERNAME_MAX_LENGTH=32
# Extra reserved names, merged with the built-in list (admin,api,www,mail,...).
# RESERVED_WORKSPACE_NAMES=vip,internal-tools
# New workspaces start on a trial of this many days (0 = created active).
# TENANT_TRIAL_DAYS=14
# Tenant-lookup cache TTLs in seconds (entries also invalidate on change).
# TENANT_CACHE_TTL=300
# TENANT_NEGATIVE_CACHE_TTL=60

# --- Request pipeline / performance ------------------------------------------
# Requests slower than this (ms) are logged at WARNING with their DB breakdown.
# SLOW_REQUEST_MS=300
# Audit events are written by a Celery worker (sync fallback if the broker is
# down). Set False to always write inline.
# AUDIT_LOG_ASYNC=True
# User<->hostel membership cache TTL (s); also invalidated on membership change.
# MEMBERSHIP_CACHE_TTL=60
# Redis cache socket bounds (s) so a hung Redis degrades instead of stalling.
# REDIS_CONNECT_TIMEOUT=1.5
# REDIS_SOCKET_TIMEOUT=1.5
# Frontend: per-request API timeout in ms (default 20000).
# NEXT_PUBLIC_API_TIMEOUT_MS=20000
# Frontend counterpart (inlined into the Next.js bundles + read by the edge
# proxy). Keep in sync with TENANT_BASE_DOMAIN above.
NEXT_PUBLIC_TENANT_BASE_DOMAIN=localhost

# --- Custom domains & white-label (Prompt 05) ---------------------------------
# Per-plan custom-domain allowances (plan_name:count, "default" for unknown).
# CUSTOM_DOMAIN_LIMITS=free:0,basic:1,professional:1,enterprise:3,default:1
# Live DNS/TLS verification probes per user (ScopedRateThrottle).
# THROTTLE_DOMAIN_VERIFY=20/hour
# NOTE (production): each activated customer domain must also be routed by the
# infrastructure — added to ALLOWED_HOSTS / CSRF_TRUSTED_ORIGINS (or fronted by
# a validating proxy) and attached to the frontend host (e.g. a Vercel domain)
# where TLS is provisioned automatically. See docs/CUSTOM_DOMAINS.md.

# --- CORS / CSRF (frontend origins) -----------------------------------------
# REQUIRED when DEBUG=False. Never use "*" in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# --- Local-dev HTTPS overlay (deploy/dev) — OPTIONAL ------------------------
# When running the single-origin TLS proxy (deploy/dev/docker-compose.https.yml),
# uncomment these so the SPA calls the same secure origin it is served from and
# CSRF accepts the https origin. See deploy/dev/README.md.
#   NEXT_PUBLIC_API_BASE_URL=https://localhost/api
#   CSRF_TRUSTED_ORIGINS=https://localhost,http://localhost:3000
#   FRONTEND_URL=https://localhost

# --- Error tracking (optional) ----------------------------------------------
# Leave blank to disable Sentry.
SENTRY_DSN=

# --- Email (password reset) -------------------------------------------------
# DEVELOPMENT uses the console backend automatically (DEBUG=True). In
# STAGING/PRODUCTION these drive real SMTP delivery.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@hostel.local

# --- Backups (encryption at rest) -------------------------------------------
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKUP_ENCRYPTION_KEY=

# --- JWT cookies ------------------------------------------------------------
# Auto-secure when DEBUG=False; override only if you know what you're doing.
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=3
# JWT_COOKIE_DOMAIN=.yourdomain.com

# --- Gunicorn tuning --------------------------------------------------------
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60

# --- Frontend (Next.js) -----------------------------------------------------
# Inlined into the browser bundle at build time. Point at the PUBLIC backend URL
# the user's browser can reach (NOT the internal compose hostname).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# --- Frontend security (Phase 10) -------------------------------------------
# Trusted Types ship REPORT-ONLY by default (violations logged, app not broken).
# After the report-only soak is clean, set to 1 to ENFORCE require-trusted-types.
# See SECURITY.md → "CSP / Trusted-Types reporting".
CSP_TT_ENFORCE=

# --- PWA Web Push (optional) ------------------------------------------------
# VAPID keypair for Web Push. Generate once with:  npx web-push generate-vapid-keys
# The PUBLIC key is inlined into the browser bundle; the PRIVATE key stays on the
# backend only. Push is disabled (and the UI hides the toggle) when unset.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- App version (shown on the system-status dashboard) ---------------------
APP_VERSION=1.0.0
NEXT_PUBLIC_APP_VERSION=1.0.0

# --- PWA analytics ----------------------------------------------------------
# How many days of raw telemetry events to keep before the nightly prune.
ANALYTICS_RETENTION_DAYS=90

# --- Host port mappings (compose) -------------------------------------------
WEB_PORT=8000
FRONTEND_PORT=3000
# Host port for direct access to the admin zone container (client zone proxies
# it at FRONTEND_PORT in normal use).
ADMIN_PORT=3001
