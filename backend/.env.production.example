# =============================================================================
# Oracle Cloud — Celery Worker environment
#
# Copy this file to `backend/.env.production` on the Oracle VM and fill in real
# values. NEVER commit the real file (.gitignore excludes .env.production).
#
#   cp backend/.env.production.example backend/.env.production
#   nano backend/.env.production
#
# This VM runs ONLY the Celery worker (and optionally Beat). The values must
# match the Render web service so producer and worker share the same broker,
# database and secrets. Redis and Postgres are EXTERNAL — use their public /
# network-reachable URLs (not the docker-internal "redis" / "postgres" hosts).
# =============================================================================

# --- Core Django -------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings
DEBUG=False
# MUST equal the SECRET_KEY on Render (signed payloads must verify on both).
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-the-same-secret-as-render
# The worker serves no HTTP, but Django still validates ALLOWED_HOSTS at import.
ALLOWED_HOSTS=localhost,127.0.0.1
# Absolute base URL used when tasks build links in emails (must match Render).
FRONTEND_URL=https://app.yourdomain.com

# --- Database (EXTERNAL — Render/managed Postgres) ---------------------------
# Use the *external* connection string, reachable from Oracle. On Render this is
# the "External Database URL". Append ?sslmode=require for managed Postgres.
DATABASE_URL=postgres://USER:PASSWORD@your-db-host:5432/hostel?sslmode=require

# --- Redis / Celery (EXTERNAL — Redis Cloud / Upstash) -----------------------
# Same broker the Render web service publishes tasks to. Use rediss:// for TLS
# (Upstash and most managed providers require it).
REDIS_URL=rediss://:PASSWORD@your-redis-host:6379/0
CELERY_BROKER_URL=rediss://:PASSWORD@your-redis-host:6379/0
CELERY_RESULT_BACKEND=rediss://:PASSWORD@your-redis-host:6379/0

# TLS certificate verification for a rediss:// URL. Applied automatically only
# when the URL scheme is rediss://; ignored for plain redis://. Silences the
# "Secure redis scheme specified (rediss) with no ssl options" warning.
#   CERT_REQUIRED  verify the cert (default; correct for Upstash / Redis Cloud)
#   CERT_NONE      skip verification (only for self-signed provider certs)
CELERY_SSL_CERT_REQS=CERT_REQUIRED

# This host is a REAL worker — never run tasks inline here.
CELERY_TASK_ALWAYS_EAGER=False

# --- Celery worker tuning (see config/settings.py; all optional) -------------
# Longest-running task ceiling before Redis redelivers (seconds). Raise above
# your slowest task (large backups) to avoid duplicate execution.
CELERY_VISIBILITY_TIMEOUT=3600
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
# Recycle a worker child after this much RSS (KB) — keeps the 1 GB VM healthy.
CELERY_WORKER_MAX_MEMORY_PER_CHILD=300000

# --- Container resource caps (docker-compose.worker.yml) ---------------------
WORKER_MEM_LIMIT=512m
WORKER_CPUS=1.0

# --- Email (transactional OTP / password reset / DR alerts) ------------------
# Required if tasks on this worker send mail. Match the Render SMTP config.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
# The worker executes tasks directly — do NOT hand mail off to a background
# thread here (that trick is only for the workerless Render deploy).
EMAIL_SEND_IN_THREAD=False

# --- Disaster recovery / backups (tasks that run on this worker) -------------
# Fernet key used to encrypt backup archives. MUST match Render or restores
# fail. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKUP_ENCRYPTION_KEY=
# Where DR failure alerts are emailed (comma-separated). Empty = log/Sentry only.
DR_ALERT_EMAILS=

# --- Object storage (must match Render so tasks read/write the same media) ---
# local = a per-host volume (NOT shared with Render — use s3 for shared media).
STORAGE_BACKEND=local
# When STORAGE_BACKEND=s3:
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=hostel-media
# S3_ENDPOINT_URL=
# S3_REGION=auto

# --- Push notifications (only if notification tasks run here) ----------------
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com

# --- Multi-tenant routing (tasks that build tenant URLs) ---------------------
TENANT_BASE_DOMAIN=yourdomain.com

# --- Observability (optional) ------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
APP_VERSION=1.0.0
# The worker layer's security middleware is HTTP-only; leave defaults.
# SECURITY_ENVIRONMENT=production

# =============================================================================
# Task routing — SET THESE ON THE RENDER WEB SERVICE (the producer), not here.
#
# The worker just executes whatever it is handed, so these variables have no
# effect on this VM (harmless if present). They decide, on Render, WHICH tasks
# are published to the broker for this worker vs. run locally on Render:
#
#   Oracle worker (broker):  DR backups + retention, AI ingestion, push fan-out
#   Render (local, no broker): OTP/transactional email, audit + security writes
#
# See docs/deployment/oracle-worker.md for the full rationale. Copy this block
# into the Render web service's environment (NOT into this file's active vars):
#
#   CELERY_TASK_ALWAYS_EAGER=False       # offload heavy tasks to this worker
#   EMAIL_TASKS_STAY_LOCAL=True          # keep OTP/email on Render (thread)
#   EMAIL_SEND_IN_THREAD=True            # email runs off-request on Render
#   AUDIT_LOG_ASYNC=False                # audit writes inline on Render
#   SECURITY_EVENTS_PERSIST_ASYNC=False  # security writes inline on Render
#
# Render and this worker MUST share the same CELERY_BROKER_URL /
# CELERY_RESULT_BACKEND (and SECRET_KEY / BACKUP_ENCRYPTION_KEY) set above.
# =============================================================================
