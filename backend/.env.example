# ===========================================================================
# Hostel SaaS — backend environment configuration
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# ===========================================================================

# --- Core ---
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-strong-random-secret
DEBUG=True
# Comma-separated; required when DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL — required in every environment) ---
# This project runs on PostgreSQL only; there is no SQLite fallback.
# Local dev defaults to postgres://hostel:hostel@localhost:5432/hostel when unset
# and DEBUG=True. Production MUST set DATABASE_URL explicitly.
#   postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgres://hostel:hostel@localhost:5432/hostel

# --- CORS / CSRF (frontend origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# --- JWT cookies ---
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=3
# In production these should be True (auto-enabled when DEBUG=False).
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax
# JWT_COOKIE_DOMAIN=.yourdomain.com

# --- Rate limiting / brute force ---
THROTTLE_ANON=60/min
THROTTLE_USER=1000/hour
THROTTLE_AUTH=5/min
AXES_ENABLED=True
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_MINUTES=15

# --- Production security toggles (active only when DEBUG=False) ---
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# --- Email (Brevo HTTP API). Dev uses console backend automatically. ---
# Prod sends via Brevo's transactional HTTP API over HTTPS/443 (no SMTP ports).
# Get the key at Brevo → SMTP & API → API Keys (starts "xkeysib-").
# EMAIL_BACKEND=apps.common.email_backends.BrevoAPIEmailBackend
# BREVO_API_KEY=
# EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@hostel.local

# --- Backups (encryption at rest) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKUP_ENCRYPTION_KEY=

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=10

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Disaster recovery (Phase 4) ---
# Backups kept per hostel, per bucket.
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
# A scheduled backup is "missing" if none succeeded within this many hours (RPO guard).
BACKUP_MAX_AGE_HOURS=26
# Where DR failure alerts are emailed (comma-separated). Empty = log/Sentry only.
DR_ALERT_EMAILS=
# Validation size sanity bounds for a stored (compressed) backup file.
# BACKUP_MIN_BYTES=20
# BACKUP_MAX_BYTES=524288000

# --- API ---
API_PAGE_SIZE=25
